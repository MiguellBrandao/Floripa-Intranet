    {
      "name": "Authentication",
      "item": [
        {
          "name": "POST /auth/login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"miguellbwork@gmail.com\",\n  \"password\": \"Nodeapp2107.\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Expected 200: accessToken + user. Refresh token via HttpOnly cookie."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/refresh",
          "request": {
            "method": "POST",
            "header": [{ "key": "Cookie", "value": "{{refreshTokenCookie}}" }],
            "url": "{{baseUrl}}/auth/refresh",
            "description": "Expected 200: new accessToken."
          }
        },
        {
          "name": "POST /auth/logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Cookie", "value": "{{refreshTokenCookie}}" }],
            "url": "{{baseUrl}}/auth/logout"
          }
        },
        {
          "name": "GET /auth/me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
